---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config/site';

const services = [
  {
    icon: '🏠',
    title: 'Compra de Vivienda',
    desc: 'Te asesoramos durante todo el proceso de compra: búsqueda, negociación, financiación y firma ante notario. Nuestro objetivo es que encuentres el hogar perfecto al mejor precio.',
    features: ['Búsqueda personalizada', 'Negociación con vendedores', 'Gestión de hipoteca', 'Acompañamiento notarial'],
  },
  {
    icon: '💰',
    title: 'Venta de Propiedades',
    desc: 'Ponemos tu propiedad en el mercado con las mejores estrategias para conseguir el mayor precio en el menor tiempo posible.',
    features: ['Valoración gratuita', 'Fotografía profesional', 'Publicidad en portales', 'Gestión de visitas'],
  },
  {
    icon: '🔑',
    title: 'Alquiler',
    desc: 'Tanto si buscas alquilar tu propiedad como si buscas un inmueble en arrendamiento, te ofrecemos un servicio integral.',
    features: ['Selección de inquilinos', 'Redacción de contratos', 'Gestión de garantías', 'Seguimiento mensual'],
  },
  {
    icon: '📊',
    title: 'Inversión Inmobiliaria',
    desc: 'Te ayudamos a identificar las mejores oportunidades de inversión con análisis de rentabilidad y asesoramiento experto.',
    features: ['Análisis de mercado', 'Cálculo de rentabilidad', 'Due diligence', 'Gestión patrimonial'],
  },
];
---

<Layout title="Servicios" description="Servicios inmobiliarios de Melero Realty: compra, venta, alquiler e inversión. Asesoramiento experto en cada paso.">
  <Header />

  <main class="flex-1">
    <section class="py-20">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-14">
          <h1 class="text-4xl font-bold mb-4" style="color: var(--color-primary)">Nuestros Servicios</h1>
          <p class="text-gray-600 max-w-xl mx-auto">Ofrecemos una gama completa de servicios inmobiliarios con el respaldo de años de experiencia en el sector.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {services.map(s => (
            <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
              <div class="text-5xl mb-4">{s.icon}</div>
              <h2 class="text-2xl font-bold mb-3" style="color: var(--color-primary)">{s.title}</h2>
              <p class="text-gray-600 mb-5 leading-relaxed">{s.desc}</p>
              <ul class="space-y-2">
                {s.features.map(f => (
                  <li class="flex items-center gap-2 text-sm text-gray-700">
                    <svg class="h-4 w-4 shrink-0" style="color: var(--color-secondary)" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="text-center mt-14">
          <p class="text-gray-600 mb-4">¿Tienes alguna duda sobre nuestros servicios?</p>
          <a href="/contacto" class="inline-block text-white font-semibold px-8 py-3 rounded-lg transition-opacity hover:opacity-90" style="background-color: var(--color-primary)">
            Contactar ahora
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
