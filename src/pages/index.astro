---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import { SITE, STATS, STATS_BIG, SERVICES, COMPARISON, TESTIMONIALS, TEAM, FAQ } from '../config/site';

const ICONS: Record<string, string> = {
  trend: 'M12 19V5M5 12l7-7 7 7',
  chat: 'M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z',
  doc: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6',
  pencil: 'M12 20h9M16.5 3.5a2.12 2.12 0 013 3L7 19l-4 1 1-4z',
  link: 'M10 13a5 5 0 007 0l3-3a5 5 0 00-7-7l-1 1M14 11a5 5 0 00-7 0l-3 3a5 5 0 007 7l1-1',
};

const CTA_TEXT = {
  heading: '¿Estás listo/a para potenciar tu agencia y abrir nuevas vías de crecimiento?',
  sub: 'Trabajamos desde la estructura, para crear sistemas sostenibles a largo plazo.',
  btn: 'Agendar un diagnóstico estratégico de negocio',
};
---

<Layout
  title="Melero Realty | Generación de Leads para Agencias Inmobiliarias"
  description="Creamos sistemas de captación de leads cualificados para agencias y asesores inmobiliarios en España y EEUU. Sin portales. Sin referidos. +300% ROI medio."
  includeFaqSchema={true}
>
  <Header />

  <main class="flex-1">

    <!-- ═══════════════════════════════
         HERO
    ════════════════════════════════ -->
    <section
      class="relative overflow-hidden py-20 md:py-28"
      style="background: var(--c-hero-gradient)"
    >
      <!-- subtle grid pattern -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, #fff 39px, #fff 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, #fff 39px, #fff 40px)"
      ></div>

      <div class="relative max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-12 md:gap-8 items-center">
        <!-- Texto -->
        <div class="text-center md:text-left">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
            Si el 80% de tus leads
            vienen de un portal,
            tienes un problema.
          </h1>

          <p class="text-lg md:text-xl text-white/60 max-w-xl mx-auto md:mx-0 mb-10 leading-relaxed">
            Creamos sistemas de captación de leads cualificados para negocios inmobiliarios en activo.
            <br class="hidden md:block" />
            Sin portales. Sin referidos. Sin curiosos.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
            <a href="/contacto" class="btn-gold text-base">
              Agenda tu llamada
            </a>
          </div>
        </div>

        <!-- Foto + tarjetas flotantes -->
        <div class="relative w-full max-w-sm mx-auto md:mx-0 md:ml-auto">
          <div class="relative aspect-[4/5] rounded-3xl overflow-hidden">
            <img
              src="/team/valeria.jpg"
              alt="Valeria Melero, CEO de Melero Realty"
              class="absolute inset-0 w-full h-full object-cover"
            />
          </div>

          <!-- avatar flotante -->
          <div
            class="absolute -top-5 -right-5 w-14 h-14 rounded-full flex items-center justify-center shadow-lg"
            style="background: linear-gradient(160deg, #7a8a8c, #4a5a5c)"
          >
            <svg class="w-6 h-6 text-white/80" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.7 0 8 1.34 8 4v2H4v-2c0-2.66 5.3-4 8-4zm0-10a4 4 0 110 8 4 4 0 010-8z"/>
            </svg>
          </div>

          <!-- tarjeta: inmobiliarias -->
          <div
            class="absolute left-[-1.5rem] bottom-[33%] flex items-center gap-2 pl-4 pr-5 py-2.5 rounded-full shadow-lg"
            style="background: rgba(20,30,32,0.75); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px)"
          >
            <span class="text-base">🏆</span>
            <span class="text-sm text-white font-medium whitespace-nowrap">{STATS[1].value} {STATS[1].label}</span>
          </div>

          <!-- tarjeta: ROI -->
          <div
            class="absolute left-[-1.5rem] bottom-[9%] w-60 p-5 rounded-2xl shadow-lg"
            style="background: rgba(0,20,24,0.8); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px)"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background: rgba(255,255,255,0.1)">⚡</span>
              <p class="text-white font-bold text-sm">Tu éxito, nuestra misión</p>
            </div>
            <p class="flex items-center gap-1.5">
              <span style="color: var(--c-accent)">↗</span>
              <span class="text-white text-lg font-black">{STATS[0].value}</span>
              <span class="text-white/50 font-medium text-sm">ROI</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         CTA INTERMEDIA
    ════════════════════════════════ -->
    <section class="px-4 pt-12 md:pt-16 pb-4" style="background: var(--c-bg)">
      <div
        class="relative overflow-hidden max-w-5xl mx-auto rounded-3xl py-16 md:py-20 px-6 text-center"
        style="background: var(--c-dark)"
      >
        <div
          class="absolute inset-0 opacity-[0.05]"
          style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, #fff 39px, #fff 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, #fff 39px, #fff 40px)"
        ></div>
        <div class="relative max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4 leading-tight">
            {CTA_TEXT.heading}
          </h2>
          <p class="text-white/60 text-lg mb-10">
            {CTA_TEXT.sub}
          </p>
          <a href="/contacto" class="btn-gold text-base">
            {CTA_TEXT.btn}
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         DECLARACIÓN DE MARCA
    ════════════════════════════════ -->
    <section class="py-16 md:py-20" style="background: var(--c-bg)">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-2xl md:text-3xl font-bold leading-snug" style="color: var(--c-dark)">
          En Melero Realty construimos el <span style="color: var(--c-muted)">sistema</span> que hace
          que los clientes <span style="color: var(--c-muted)">lleguen a ti</span>, no al revés.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════
         SERVICIOS
    ════════════════════════════════ -->
    <section id="servicios" class="py-20" style="background: var(--c-bg-lt)">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-14">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--c-accent)">Lo que hacemos</p>
          <h2 class="text-3xl md:text-4xl font-black mb-4" style="color: var(--c-dark)">
            Un sistema completo de captación
          </h2>
          <p class="text-base max-w-xl mx-auto" style="color: var(--c-muted)">
            Cada servicio está diseñado para que tu agencia capte leads de calidad sin depender de terceros.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {SERVICES.map(({ icon, title, desc }) => (
            <div class="rounded-2xl p-6 bg-white">
              <span class="w-11 h-11 rounded-full flex items-center justify-center mb-4 shadow-md ring-1 ring-black/5 bg-white">
                {icon === 'percent'
                  ? <span class="text-lg font-bold" style="color: var(--c-dark)">%</span>
                  : <svg class="w-5 h-5" style="color: var(--c-dark)" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={ICONS[icon]}/></svg>
                }
              </span>
              <h3 class="font-bold text-lg mb-2" style="color: var(--c-dark)">{title}</h3>
              {desc
                ? <p class="text-sm leading-relaxed" style="color: var(--c-muted)">{desc}</p>
                : <p class="text-sm italic" style="color: var(--c-muted)/60">Descripción próximamente.</p>
              }
            </div>
          ))}
        </div>

        <div class="text-center mt-12">
          <a href="/contacto" class="btn-gold">Quiero empezar</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         POR QUÉ MELERO REALTY — vídeo + métricas
    ════════════════════════════════ -->
    <section id="resultados" class="relative overflow-hidden py-20" style="background: var(--c-dark)">
      <div
        class="absolute inset-0 opacity-[0.05]"
        style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, #fff 39px, #fff 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, #fff 39px, #fff 40px)"
      ></div>

      <div class="relative max-w-4xl mx-auto px-4">
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
            Por qué Melero Realty
          </h2>
          <p class="text-white/60 max-w-lg mx-auto">
            No somos una agencia generalista que también hace inmobiliario. Solo hacemos esto.
          </p>
        </div>

        <!-- Video + badges flotantes -->
        <div class="relative max-w-2xl mx-auto pb-10 pl-6 md:pl-10">
          <VideoEmbed videoId={SITE.youtubeId} title="Por qué Melero Realty" />

          <!-- badge: experiencia -->
          <div
            class="absolute left-0 bottom-0 flex items-center gap-2 pl-4 pr-5 py-2.5 rounded-full"
            style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px)"
          >
            <span class="text-base">✨</span>
            <span class="text-sm text-white font-medium whitespace-nowrap">+3 Años de Experiencia</span>
          </div>

          <!-- badge: resultados -->
          <div
            class="absolute right-2 top-6 md:right-4 md:top-8 flex items-center gap-3 pl-3 pr-5 py-2.5 rounded-full"
            style="background: rgba(13,13,13,0.7); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px)"
          >
            <span class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background: rgba(255,255,255,0.1)">📊</span>
            <span class="text-sm text-white font-medium leading-snug">Resultados medibles,<br/>no promesas</span>
          </div>
        </div>

        <!-- Stats grandes -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-16 text-center">
          {STATS_BIG.map(({ value, label }) => (
            <div>
              <p class="text-4xl md:text-5xl font-black text-white">{value}</p>
              <p class="text-white/50 mt-2 text-sm">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         TABLA COMPARATIVA
    ════════════════════════════════ -->
    <section class="py-20" style="background: var(--c-dark)">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
            Por qué Melero Realty y no otra agencia
          </h2>
          <p class="text-white/60">La diferencia está en lo que medimos.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <p class="text-sm font-bold text-white/50 text-center mb-4">Otras Agencias</p>
            <div class="rounded-2xl border border-white/15 p-6 space-y-4">
              {COMPARISON.map(({ ellos }) => (
                <div class="flex items-start gap-3 text-sm text-white/60">
                  <span class="mt-0.5 shrink-0 w-4 h-4 rounded-full border border-white/30 flex items-center justify-center text-[10px]">✕</span>
                  {ellos}
                </div>
              ))}
            </div>
          </div>

          <div>
            <p class="text-sm font-bold text-white text-center mb-4">Melero Realty</p>
            <div
              class="rounded-2xl border border-white/15 p-6 space-y-4"
              style="background: linear-gradient(160deg, #33824d, var(--c-dark) 70%)"
            >
              {COMPARISON.map(({ nosotros }) => (
                <div class="flex items-start gap-3 text-sm text-white font-medium">
                  <span class="mt-0.5 shrink-0 w-4 h-4 rounded-full bg-white/20 flex items-center justify-center text-[10px]">✓</span>
                  {nosotros}
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="text-center mt-12">
          <a href="/contacto" class="btn-gold">Agenda tu diagnóstico gratuito</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         TESTIMONIOS
    ════════════════════════════════ -->
    <section id="testimonios" class="py-20" style="background: var(--c-bg)">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-black mb-3" style="color: var(--c-dark)">
            Lo que dicen los que ya trabajan con nosotros
          </h2>
          <p style="color: var(--c-muted)">Sin filtros.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {TESTIMONIALS.map(({ quote, name, role }) => (
            <div class="rounded-2xl p-7 flex flex-col" style="background: var(--c-bg-lt)">
              <p class="text-base leading-relaxed flex-1" style="color: var(--c-text)">{quote}</p>
              <div class="mt-5">
                <p class="font-bold text-sm" style="color: var(--c-dark)">{name}</p>
                <p class="text-xs mt-0.5" style="color: var(--c-muted)">{role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         EQUIPO
    ════════════════════════════════ -->
    <section id="equipo" class="py-20" style="background: var(--c-bg-lt)">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-black mb-3" style="color: var(--c-dark)">
            Quiénes están detrás
          </h2>
          <p style="color: var(--c-muted)">Un equipo pequeño, especializado y con las manos en la masa.</p>
        </div>

        <div class="grid grid-cols-2 gap-6 max-w-2xl mx-auto">
          {TEAM.map(({ name, role, photo }) => (
            <div class="relative aspect-[3/4] rounded-2xl overflow-hidden">
              <img src={photo} alt={name} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.75) 100%)"></div>
              <div class="absolute bottom-0 left-0 right-0 p-5">
                <p class="font-bold text-white">{name}</p>
                <p class="text-white/70 text-sm mt-0.5 leading-snug">{role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         FAQ
    ════════════════════════════════ -->
    <section id="faq" class="py-20" style="background: var(--c-bg-lt)">
      <div class="max-w-2xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-black mb-3" style="color: var(--c-dark)">
            Lo que nos suelen preguntar
          </h2>
          <p style="color: var(--c-muted)">Si tienes otra duda, escríbenos.</p>
        </div>

        <div class="space-y-3">
          {FAQ.map(({ q, a }) => (
            <details class="rounded-xl overflow-hidden group" style="background: var(--c-bg)">
              <summary class="flex items-center justify-between px-5 py-4 font-semibold text-sm cursor-pointer select-none" style="color: var(--c-dark)">
                {q}
                <span class="faq-icon ml-4 shrink-0 text-lg leading-none" style="color: var(--c-dark)">+</span>
              </summary>
              <div class="px-5 pb-5 text-sm leading-relaxed" style="color: var(--c-muted)">
                {a
                  ? a
                  : <span class="italic opacity-50">Respuesta próximamente.</span>
                }
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         CTA FINAL
    ════════════════════════════════ -->
    <section class="px-4 py-16 md:py-20" style="background: var(--c-bg-lt)">
      <div
        class="relative overflow-hidden max-w-5xl mx-auto rounded-3xl py-16 md:py-20 px-6 text-center"
        style="background: var(--c-dark)"
      >
        <div
          class="absolute inset-0 opacity-[0.05]"
          style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, #fff 39px, #fff 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, #fff 39px, #fff 40px)"
        ></div>
        <div class="relative max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4 leading-tight">
            {CTA_TEXT.heading}
          </h2>
          <p class="text-white/60 text-lg mb-10">
            {CTA_TEXT.sub}
          </p>
          <a href="/contacto" class="btn-gold text-base">
            {CTA_TEXT.btn}
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
