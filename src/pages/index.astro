---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import { SITE, STATS, STATS_BIG, SERVICES, COMPARISON, TESTIMONIALS, TEAM, FAQ } from '../config/site';
---

<Layout
  title="Melero Realty | Generación de Leads para Agencias Inmobiliarias"
  description="Creamos sistemas de captación de leads cualificados para agencias y asesores inmobiliarios en España y EEUU. Sin portales. Sin referidos. +300% ROI medio."
  includeFaqSchema={true}
>
  <Header />

  <main class="flex-1">

    <!-- ═══════════════════════════════
         HERO
    ════════════════════════════════ -->
    <section
      class="relative overflow-hidden py-20 md:py-28"
      style="background: var(--c-hero-gradient)"
    >
      <!-- subtle grid pattern -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, #fff 39px, #fff 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, #fff 39px, #fff 40px)"
      ></div>

      <div class="relative max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-12 md:gap-8 items-center">
        <!-- Texto -->
        <div class="text-center md:text-left">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
            Si el 80% de tus leads
            vienen de un portal,
            tienes un problema.
          </h1>

          <p class="text-lg md:text-xl text-white/60 max-w-xl mx-auto md:mx-0 mb-10 leading-relaxed">
            Creamos sistemas de captación de leads cualificados para negocios inmobiliarios en activo.
            <br class="hidden md:block" />
            Sin portales. Sin referidos. Sin curiosos.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
            <a href="/contacto" class="btn-gold text-base">
              Agenda tu llamada
            </a>
          </div>
        </div>

        <!-- Foto + tarjetas flotantes -->
        <div class="relative max-w-sm mx-auto md:mx-0 md:ml-auto pb-16 pr-6 md:pb-20 md:pr-10">
          <div
            class="relative aspect-[4/5] rounded-3xl overflow-hidden"
            style="background: linear-gradient(160deg, var(--c-navy), var(--c-dark))"
          >
            <!-- placeholder: sustituir por foto real del equipo -->
            <svg class="absolute inset-0 w-full h-full text-white/10" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.7 0 8 1.34 8 4v2H4v-2c0-2.66 5.3-4 8-4zm0-10a4 4 0 110 8 4 4 0 010-8z"/>
            </svg>

            <!-- avatar flotante -->
            <div class="absolute -top-4 -right-4 w-14 h-14 rounded-full flex items-center justify-center border-4 border-white/10" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(4px)">
              <svg class="w-6 h-6 text-white/70" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.7 0 8 1.34 8 4v2H4v-2c0-2.66 5.3-4 8-4zm0-10a4 4 0 110 8 4 4 0 010-8z"/>
              </svg>
            </div>
          </div>

          <!-- tarjeta: inmobiliarias -->
          <div
            class="absolute left-0 bottom-24 md:bottom-28 flex items-center gap-2 pl-4 pr-5 py-2.5 rounded-full"
            style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px)"
          >
            <span class="text-base">🏆</span>
            <span class="text-sm text-white font-medium whitespace-nowrap">{STATS[1].value} {STATS[1].label}</span>
          </div>

          <!-- tarjeta: ROI -->
          <div
            class="absolute left-0 bottom-0 w-64 p-5 rounded-2xl"
            style="background: rgba(0,35,41,0.6); border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px)"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background: rgba(255,255,255,0.1)">⚡</span>
              <p class="text-white font-bold text-sm">Tu éxito, nuestra misión</p>
            </div>
            <p class="flex items-center gap-1.5">
              <span style="color: var(--c-accent)">↗</span>
              <span class="text-white text-lg font-black">{STATS[0].value}</span>
              <span class="text-white/50 font-medium text-sm">ROI</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         DECLARACIÓN DE MARCA
    ════════════════════════════════ -->
    <section class="py-16 md:py-20" style="background: var(--c-bg)">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-2xl md:text-3xl font-bold leading-snug" style="color: var(--c-dark)">
          En <span style="color: var(--c-accent)">Melero Realty</span> construimos el sistema
          que hace que los clientes lleguen a ti, no al revés.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════
         SERVICIOS
    ════════════════════════════════ -->
    <section id="servicios" class="py-20" style="background: var(--c-bg-lt)">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-14">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--c-accent)">Lo que hacemos</p>
          <h2 class="text-3xl md:text-4xl font-black mb-4" style="color: var(--c-dark)">
            Un sistema completo de captación
          </h2>
          <p class="text-base max-w-xl mx-auto" style="color: var(--c-muted)">
            Cada servicio está diseñado para que tu agencia capte leads de calidad sin depender de terceros.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {SERVICES.map(({ icon, title, desc }) => (
            <div class="bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
              <span class="text-4xl block mb-4">{icon}</span>
              <h3 class="font-bold text-lg mb-2" style="color: var(--c-dark)">{title}</h3>
              {desc
                ? <p class="text-sm leading-relaxed" style="color: var(--c-muted)">{desc}</p>
                : <p class="text-sm italic" style="color: var(--c-muted)/60">Descripción próximamente.</p>
              }
            </div>
          ))}
        </div>

        <div class="text-center mt-12">
          <a href="/contacto" class="btn-gold">Quiero empezar</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         POR QUÉ MELERO REALTY — vídeo + métricas
    ════════════════════════════════ -->
    <section id="resultados" class="py-20" style="background: var(--c-dark)">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-14">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--c-accent)">Por qué Melero Realty</p>
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
            Resultados que puedes medir
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-12 items-center">
          <!-- Video lazy -->
          <div>
            <VideoEmbed videoId={SITE.youtubeId} title="Por qué Melero Realty" />
          </div>

          <!-- Big stats -->
          <div class="flex flex-col gap-8">
            {STATS_BIG.map(({ value, label }) => (
              <div class="border-l-4 pl-6" style="border-color: var(--c-accent)">
                <p class="text-5xl font-black" style="color: var(--c-accent)">{value}</p>
                <p class="text-white/60 mt-1">{label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         TABLA COMPARATIVA
    ════════════════════════════════ -->
    <section class="py-20" style="background: var(--c-bg)">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--c-accent)">La diferencia</p>
          <h2 class="text-3xl md:text-4xl font-black mb-4" style="color: var(--c-dark)">
            Otras agencias vs. Melero Realty
          </h2>
        </div>

        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
          <!-- Header row -->
          <div class="grid grid-cols-2">
            <div class="py-3 px-6 text-sm font-bold text-white/80 text-center bg-gray-400/60">
              Otras agencias
            </div>
            <div class="py-3 px-6 text-sm font-bold text-center text-white" style="background: var(--c-navy)">
              Melero Realty
            </div>
          </div>

          {COMPARISON.map(({ ellos, nosotros }, i) => (
            <div class={`grid grid-cols-2 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
              <div class="py-4 px-6 text-sm border-r border-gray-200 flex items-start gap-2 text-gray-500">
                <span class="mt-0.5 text-red-400 shrink-0">✗</span>
                {ellos}
              </div>
              <div class="py-4 px-6 text-sm flex items-start gap-2 font-medium" style="color: var(--c-navy)">
                <span class="mt-0.5 shrink-0" style="color: var(--c-accent)">✓</span>
                {nosotros}
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-10">
          <a href="/contacto" class="btn-gold">Agenda tu diagnóstico gratuito</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         TESTIMONIOS
    ════════════════════════════════ -->
    <section class="py-20" style="background: var(--c-bg-lt)">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--c-accent)">Clientes</p>
          <h2 class="text-3xl md:text-4xl font-black" style="color: var(--c-dark)">
            Lo que dicen quienes ya escalan
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {TESTIMONIALS.map(({ quote, name, role }) => (
            <div class="bg-white rounded-2xl p-7 border border-gray-100 flex flex-col">
              <svg class="w-8 h-8 mb-4 opacity-30" style="color: var(--c-accent)" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
              <p class="text-base leading-relaxed flex-1" style="color: var(--c-text)">"{quote}"</p>
              <div class="mt-5 pt-5 border-t border-gray-100">
                <p class="font-bold text-sm" style="color: var(--c-dark)">{name}</p>
                <p class="text-xs mt-0.5" style="color: var(--c-muted)">{role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         EQUIPO
    ════════════════════════════════ -->
    <section class="py-20" style="background: var(--c-dark)">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--c-accent)">El equipo</p>
          <h2 class="text-3xl md:text-4xl font-black text-white">
            Las personas detrás de tus resultados
          </h2>
        </div>

        <div class="grid grid-cols-2 gap-6 max-w-2xl mx-auto">
          {TEAM.map(({ name, role, photo }) => (
            <div class="relative aspect-[3/4] rounded-2xl overflow-hidden">
              <img src={photo} alt={name} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.75) 100%)"></div>
              <div class="absolute bottom-0 left-0 right-0 p-5">
                <p class="font-bold text-white">{name}</p>
                <p class="text-white/70 text-sm mt-0.5 leading-snug">{role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         FAQ
    ════════════════════════════════ -->
    <section class="py-20" style="background: var(--c-bg)">
      <div class="max-w-2xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--c-accent)">FAQ</p>
          <h2 class="text-3xl md:text-4xl font-black" style="color: var(--c-dark)">
            Preguntas frecuentes
          </h2>
        </div>

        <div class="space-y-3">
          {FAQ.map(({ q, a }) => (
            <details class="rounded-xl border border-gray-200 overflow-hidden group">
              <summary class="flex items-center justify-between px-5 py-4 font-semibold text-sm cursor-pointer select-none" style="color: var(--c-dark)">
                {q}
                <span class="faq-icon ml-4 shrink-0 text-lg leading-none" style="color: var(--c-accent)">+</span>
              </summary>
              <div class="px-5 pb-5 text-sm leading-relaxed" style="color: var(--c-muted)">
                {a
                  ? a
                  : <span class="italic opacity-50">Respuesta próximamente.</span>
                }
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         CTA FINAL
    ════════════════════════════════ -->
    <section class="py-24" style="background: var(--c-navy)">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight">
          ¿Listo para dejar de<br class="hidden md:block" />
          depender de portales?
        </h2>
        <p class="text-white/60 text-lg mb-10 max-w-xl mx-auto">
          Agenda un diagnóstico estratégico gratuito. En 30 minutos sabemos si podemos ayudarte y cómo.
        </p>
        <a href="/contacto" class="btn-gold text-base">
          Agendar diagnóstico estratégico de negocio →
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
