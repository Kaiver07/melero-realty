---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config/site';
---

<Layout
  title="Diagnóstico de Captación Inmobiliaria"
  description="Agenda tu diagnóstico estratégico gratuito con Melero Realty. Analizamos tu captación actual y te decimos exactamente qué cambiaría con nuestro sistema."
>
  <Header />

  <main class="flex-1 py-16" style="background: var(--c-bg-lt)">
    <div class="max-w-2xl mx-auto px-4">

      <!-- Intro -->
      <div class="text-center mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--c-accent)">Primer paso</p>
        <h1 class="text-3xl md:text-4xl font-black mb-3" style="color: var(--c-dark)">
          Diagnóstico de Captación Inmobiliaria
        </h1>
        <p class="text-base" style="color: var(--c-muted)">
          Rellena este formulario y analizamos tu situación actual. Solo trabajamos con agencias con las que podemos generar un impacto real.
        </p>
      </div>

      <!-- Progress bar -->
      <div class="mb-8">
        <div class="flex justify-between text-xs mb-2" style="color: var(--c-muted)">
          <span id="step-label">Paso 1 de 5</span>
          <span id="step-pct">20%</span>
        </div>
        <div class="h-1.5 rounded-full bg-gray-200 overflow-hidden">
          <div id="progress-bar" class="h-full rounded-full transition-all duration-300" style="background: var(--c-accent); width: 20%"></div>
        </div>
      </div>

      <!-- Form -->
      <form
        id="diag-form"
        data-sheets-url={SITE.sheetsWebAppUrl}
        class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden"
      >
        <!-- ── PASO 1: Perfil ── -->
        <fieldset data-step="1" class="step-panel px-6 py-8 space-y-5">
          <legend class="text-lg font-bold mb-6" style="color: var(--c-dark)">Cuéntanos sobre ti</legend>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">Nombre completo *</label>
            <input type="text" name="nombre" required placeholder="Tu nombre" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors" />
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">Teléfono / WhatsApp *</label>
            <input type="tel" name="telefono" required placeholder="+34 600 000 000" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors" />
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">Instagram o web de tu negocio *</label>
            <input type="text" name="instagram_web" required placeholder="@tuagencia o https://tuagencia.com" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors" />
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">¿Cuál es tu rol actualmente? *</label>
            <div class="space-y-2">
              {['Asesor/a inmobiliario', 'Dueño/a de agencia'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" name="rol" value={opt} required class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">¿En qué zona trabajas principalmente? *</label>
            <input type="text" name="zona" required placeholder="Ej: Madrid, Barcelona, Miami…" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors" />
          </div>
        </fieldset>

        <!-- ── PASO 2: Tu negocio ── -->
        <fieldset data-step="2" class="step-panel hidden px-6 py-8 space-y-5">
          <legend class="text-lg font-bold mb-6" style="color: var(--c-dark)">Tu negocio</legend>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--c-dark)">¿Qué tipo de propiedades trabajas? *</label>
            <div class="space-y-2">
              {['Residencial', 'Lujo', 'Inversión', 'Promociones / obra nueva', 'Variado'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="checkbox" name="tipo_propiedades" value={opt} class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">¿Cómo estás consiguiendo clientes actualmente? *</label>
            <textarea name="captacion_actual" required rows="3" placeholder="Portales, referidos, redes sociales…" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors resize-none"></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--c-dark)">¿Estás invirtiendo en publicidad ahora mismo? *</label>
            <div class="space-y-2">
              {['Sí, de forma constante', 'Sí, pero sin estructura', 'No'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" name="publicidad" value={opt} required class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>
        </fieldset>

        <!-- ── PASO 3: Números ── -->
        <fieldset data-step="3" class="step-panel hidden px-6 py-8 space-y-5">
          <legend class="text-lg font-bold mb-6" style="color: var(--c-dark)">Tus números</legend>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--c-dark)">¿Cuántos leads generas al mes aproximadamente? *</label>
            <div class="space-y-2">
              {['Menos de 10', '10-30', '30-100', '+100'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" name="leads_mes" value={opt} required class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--c-dark)">¿Qué porcentaje de esos leads se convierten en clientes reales? *</label>
            <div class="space-y-2">
              {['Muy bajo', 'Medio', 'Alto', 'No lo tengo medido'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" name="conversion" value={opt} required class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--c-dark)">Facturación mensual aproximada *</label>
            <div class="space-y-2">
              {['Menos de 3.000€', '3.000€ - 10.000€', '10.000€ - 30.000€', '+30.000€'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" name="facturacion" value={opt} required class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>
        </fieldset>

        <!-- ── PASO 4: Situación y objetivos ── -->
        <fieldset data-step="4" class="step-panel hidden px-6 py-8 space-y-5">
          <legend class="text-lg font-bold mb-6" style="color: var(--c-dark)">Tu situación y objetivos</legend>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">¿Cuál es tu objetivo realista para los próximos 6 meses? *</label>
            <textarea name="objetivo_6m" required rows="3" placeholder="Duplicar leads, cerrar 5 ventas más al mes…" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors resize-none"></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">¿Cuál es el mayor bloqueo ahora mismo en tu captación o ventas? *</label>
            <textarea name="bloqueo" required rows="3" placeholder="Cuéntanos qué es lo que más te frena" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors resize-none"></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">¿Qué has probado hasta ahora que no ha funcionado? *</label>
            <textarea name="intentado" required rows="3" placeholder="Agencias, portales, ads por tu cuenta…" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors resize-none"></textarea>
          </div>
        </fieldset>

        <!-- ── PASO 5: Decisión + envío ── -->
        <fieldset data-step="5" class="step-panel hidden px-6 py-8 space-y-5">
          <legend class="text-lg font-bold mb-6" style="color: var(--c-dark)">Antes de terminar</legend>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--c-dark)">¿Qué prioridad tiene para ti resolver esto? *</label>
            <div class="space-y-2">
              {['Urgente (lo necesito ya)', 'Alto (quiero resolverlo en breve)', 'Media (estoy explorando opciones)'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" name="prioridad" value={opt} required class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--c-dark)">¿Podrías tomar una decisión económica hoy solo/a? *</label>
            <div class="space-y-2">
              {['Sí', 'No, dependo de socios', 'No, dependo de otra persona'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" name="decisor" value={opt} required class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-2" style="color: var(--c-dark)">Capital líquido disponible hoy para implementar una solución *</label>
            <div class="space-y-2">
              {['Menos de 1.000€', 'Menos de 1.000€ pero puedo conseguir más', '1.000€ - 3.000€', '3.000€ - 6.000€', '+6.000€'].map(opt => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" name="capital" value={opt} required class="accent-amber-500" />
                  <span class="text-sm" style="color: var(--c-text)">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5" style="color: var(--c-dark)">¿Por qué quieres escalar ahora tu negocio? *</label>
            <textarea name="por_que_ahora" required rows="3" placeholder="Cuéntanos qué te ha llevado a buscar una solución ahora" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-gray-400 transition-colors resize-none"></textarea>
          </div>

          <!-- Consent -->
          <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" name="consentimiento" value="De acuerdo" required class="mt-0.5 accent-amber-500" />
              <span class="text-xs leading-relaxed" style="color: var(--c-muted)">
                Acepto recibir comunicaciones comerciales y promociones de Melero Realty. Entiendo que mis datos serán tratados conforme a la
                <a href="/politica-de-privacidad" class="underline hover:text-gray-900" style="color: var(--c-navy)" target="_blank">política de privacidad</a>
                y que puedo darme de baja en cualquier momento.
              </span>
            </label>
          </div>
        </fieldset>

        <!-- Navigation buttons -->
        <div class="flex items-center justify-between px-6 py-5 border-t border-gray-100 bg-gray-50">
          <button
            type="button"
            id="btn-prev"
            class="text-sm font-semibold px-5 py-2.5 rounded-xl border border-gray-300 text-gray-600 hover:bg-gray-100 transition-colors invisible"
          >
            ← Anterior
          </button>

          <button
            type="button"
            id="btn-next"
            class="btn-gold text-sm"
          >
            Siguiente →
          </button>

          <button
            type="submit"
            id="btn-submit"
            class="btn-gold text-sm hidden"
          >
            Enviar diagnóstico →
          </button>
        </div>
      </form>

      <!-- Success message (hidden) -->
      <div id="form-success" class="hidden text-center py-16">
        <div class="text-5xl mb-4">🎯</div>
        <h2 class="text-2xl font-black mb-2" style="color: var(--c-dark)">¡Diagnóstico recibido!</h2>
        <p class="text-base mb-6" style="color: var(--c-muted)">
          Revisaremos tu caso y nos pondremos en contacto contigo en las próximas 24-48h.
        </p>
        <a href="/" class="btn-gold">Volver al inicio</a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  const TOTAL = 5;
  let current = 1;

  const steps  = () => document.querySelectorAll<HTMLElement>('.step-panel');
  const bar    = document.getElementById('progress-bar')!;
  const label  = document.getElementById('step-label')!;
  const pct    = document.getElementById('step-pct')!;
  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  const btnSub  = document.getElementById('btn-submit') as HTMLButtonElement;
  const form    = document.getElementById('diag-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;

  function showStep(n: number) {
    steps().forEach(s => {
      const active = Number(s.dataset.step) === n;
      s.classList.toggle('hidden', !active);
    });

    const progress = Math.round((n / TOTAL) * 100);
    bar.style.width = `${progress}%`;
    label.textContent = `Paso ${n} de ${TOTAL}`;
    pct.textContent = `${progress}%`;

    btnPrev.classList.toggle('invisible', n === 1);
    btnNext.classList.toggle('hidden', n === TOTAL);
    btnSub.classList.toggle('hidden', n !== TOTAL);
  }

  function validateCurrentStep(): boolean {
    const panel = document.querySelector<HTMLElement>(`.step-panel[data-step="${current}"]`)!;
    const required = panel.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('[required]');
    let valid = true;
    required.forEach(el => {
      if (el.type === 'radio' || el.type === 'checkbox') {
        const name = el.name;
        const checked = panel.querySelector<HTMLInputElement>(`[name="${name}"]:checked`);
        if (!checked) { valid = false; el.closest('div')?.classList.add('outline-red-300'); }
      } else if (!el.value.trim()) {
        valid = false;
        el.classList.add('border-red-300');
      }
    });
    return valid;
  }

  btnNext.addEventListener('click', () => {
    if (!validateCurrentStep()) return;
    current++;
    showStep(current);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  btnPrev.addEventListener('click', () => {
    current--;
    showStep(current);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Envío a Google Sheets vía Apps Script
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btnSub.disabled = true;
    btnSub.textContent = 'Enviando…';

    const data = new FormData(form);
    try {
      const res = await fetch(form.dataset.sheetsUrl!, {
        method: 'POST',
        body: data,
      });

      if (!res.ok) throw new Error('request failed');

      form.classList.add('hidden');
      success.classList.remove('hidden');
      document.getElementById('diag-form')?.previousElementSibling?.classList.add('hidden');
    } catch {
      btnSub.disabled = false;
      btnSub.textContent = 'Enviar diagnóstico →';
      alert('Hubo un error al enviar. Por favor, inténtalo de nuevo.');
    }
  });

  showStep(1);
</script>
