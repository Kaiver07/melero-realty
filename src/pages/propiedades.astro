---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Propiedades" description="Explora nuestro catálogo de propiedades en venta y alquiler. Pisos, casas y locales con Melero Realty.">
  <Header />

  <main class="flex-1">
    <section class="py-20">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-12">
          <h1 class="text-4xl font-bold mb-4" style="color: var(--color-primary)">Nuestras Propiedades</h1>
          <p class="text-gray-600 max-w-xl mx-auto">Descubre nuestra selección de propiedades disponibles para compra y alquiler.</p>
        </div>

        <!-- Próximamente -->
        <div class="text-center py-20 bg-gray-50 rounded-2xl border border-dashed border-gray-300">
          <div class="text-6xl mb-4">🏡</div>
          <h2 class="text-2xl font-bold mb-2" style="color: var(--color-primary)">Catálogo en construcción</h2>
          <p class="text-gray-500 mb-6 max-w-md mx-auto">Pronto tendremos disponible nuestro catálogo completo de propiedades. Mientras tanto, contacta con nosotros para conocer nuestras ofertas.</p>
          <a href="/contacto" class="inline-block text-white font-semibold px-6 py-3 rounded-lg transition-opacity hover:opacity-90" style="background-color: var(--color-primary)">
            Contactar para más info
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
