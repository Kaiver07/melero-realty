---
interface Props { videoId: string; title?: string; }
const { videoId, title = 'Ver vídeo' } = Astro.props;
const thumb = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
---

<div
  class="yt-facade"
  data-video-id={videoId}
  role="button"
  tabindex="0"
  aria-label={title}
>
  <img src={thumb} alt={title} loading="lazy" decoding="async" />
  <div class="yt-play">
    <svg viewBox="0 0 68 48" xmlns="http://www.w3.org/2000/svg">
      <path d="M66.52 7.74C65.7 4.7 63.3 2.3 60.25 1.48 54.98 0 34 0 34 0S13.02 0 7.75 1.48C4.7 2.3 2.3 4.7 1.48 7.74 0 13.02 0 24 0 24s0 10.98 1.48 16.26C2.3 43.3 4.7 45.7 7.75 46.52 13.02 48 34 48 34 48s20.98 0 26.25-1.48C63.3 45.7 65.7 43.3 66.52 40.26 68 34.98 68 24 68 24s0-10.98-1.48-16.26z" fill="#fff" fill-opacity=".9"/>
      <path d="M27 34.5l18-10.5L27 13.5v21z" fill="var(--c-dark)"/>
    </svg>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.yt-facade').forEach(el => {
    const activate = () => {
      const id = el.dataset.videoId;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;border-radius:0.75rem';
      el.innerHTML = '';
      el.appendChild(iframe);
    };
    el.addEventListener('click', activate);
    el.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') activate(); });
  });
</script>
