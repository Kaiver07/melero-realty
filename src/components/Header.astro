---
const nav = [
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#resultados', label: 'Nuestro trabajo' },
  { href: '/sobre-nosotros', label: 'Sobre nosotros' },
];
---

<header
  class="sticky top-0 z-50 border-b border-white/10"
  style="background: var(--c-dark)"
>
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between gap-6">

    <!-- Logo -->
    <a href="/" class="shrink-0 flex items-baseline gap-1">
      <span class="text-xl font-bold text-white tracking-tight">Melero</span>
      <span class="text-xl font-light text-white/80">Realty</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-7">
      {nav.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm font-medium text-white/70 hover:text-white transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a href="/contacto" class="btn-gold shrink-0 text-sm hidden sm:inline-block">
      Contáctanos
    </a>

    <!-- Mobile burger -->
    <button
      id="burger"
      class="md:hidden p-2 text-white/70 hover:text-white"
      aria-label="Abrir menú"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="burger-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        <path id="burger-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10">
    <ul class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-3">
      {nav.map(({ href, label }) => (
        <li>
          <a href={href} class="block text-white/80 hover:text-white py-1 text-sm font-medium">
            {label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/contacto" class="btn-gold text-sm w-full text-center block">
          Contáctanos
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const burger = document.getElementById('burger')!;
  const menu   = document.getElementById('mobile-menu')!;
  const open   = document.getElementById('burger-open')!;
  const close  = document.getElementById('burger-close')!;

  burger.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    open.classList.toggle('hidden', !isOpen);
    close.classList.toggle('hidden', isOpen);
  });

  // Close on nav link click
  menu.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      open.classList.remove('hidden');
      close.classList.add('hidden');
    })
  );
</script>
