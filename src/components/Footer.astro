---
import { SITE } from '../config/site';
const year = new Date().getFullYear();

const secciones = [
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#equipo', label: 'Equipo' },
  { href: '/#testimonios', label: 'Testimonios' },
];
const informacion = [
  { href: '/#faq', label: "FAQ's" },
  { href: '/contacto', label: 'Contacto' },
];
const legal = [
  { href: '/aviso-legal', label: 'Aviso legal' },
  { href: '/politica-de-privacidad', label: 'Privacidad' },
  { href: '/politica-de-cookies', label: 'Cookies' },
];
---

<footer style="background: var(--c-dark)" class="text-white mt-auto">

  <!-- Newsletter -->
  <div class="border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 py-12 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-lg font-bold">Únete a la familia Melero.Realty</p>
        <p class="text-white/50 text-sm mt-1">Suscríbete y no te pierdas nada. Obtendrás descuentos únicos y te enterarás antes que nadie.</p>
      </div>
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="flex gap-2 w-full md:w-auto"
      >
        <input type="hidden" name="access_key" value={SITE.web3formsKey} />
        <input type="hidden" name="subject" value="Nueva suscripción newsletter" />
        <input type="hidden" name="redirect" value="false" />
        <input
          type="email"
          name="email"
          required
          placeholder="tu@email.com"
          class="flex-1 md:w-64 px-4 py-2.5 rounded-lg text-sm bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-white/40"
        />
        <button
          type="submit"
          class="btn-gold text-sm whitespace-nowrap"
        >
          Notifícame
        </button>
      </form>
    </div>
  </div>

  <!-- Main footer -->
  <div class="max-w-6xl mx-auto px-4 py-10 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <a href="/" class="flex items-baseline gap-1 mb-3">
        <span class="text-lg font-bold">Melero</span>
        <span class="text-lg font-light text-white/80">Realty</span>
      </a>
      <p class="text-white/50 text-sm leading-relaxed max-w-xs">
        Generación de leads cualificados para agencias y asesores inmobiliarios. España y EEUU.
      </p>
      <a
        href={SITE.social.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 mt-4 text-sm text-white/50 hover:text-white transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        @melerorealty
      </a>
    </div>

    <div>
      <p class="text-xs uppercase tracking-widest text-white/40 mb-4">Secciones</p>
      <ul class="space-y-2">
        {secciones.map(({ href, label }) => (
          <li>
            <a href={href} class="text-sm text-white/60 hover:text-white transition-colors">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-xs uppercase tracking-widest text-white/40 mb-4">Información</p>
      <ul class="space-y-2">
        {informacion.map(({ href, label }) => (
          <li>
            <a href={href} class="text-sm text-white/60 hover:text-white transition-colors">
              {label}
            </a>
          </li>
        ))}
      </ul>
      <a
        href={`mailto:${SITE.email}`}
        class="text-sm text-white/60 hover:text-white transition-colors block mt-2"
      >
        {SITE.email}
      </a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white/30">
      <p>© {year} {SITE.name}. Todos los derechos reservados.</p>
      <div class="flex gap-4">
        {legal.map(({ href, label }) => (
          <a href={href} class="hover:text-white/60 transition-colors">{label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
