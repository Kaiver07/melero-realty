---
import { SITE } from '../config/site';

const year = new Date().getFullYear();
---

<footer style="background-color: var(--color-primary)" class="text-white mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <div class="mb-3">
        <span class="text-2xl font-bold">Melero</span>
        <span class="text-2xl font-light" style="color: var(--color-secondary)"> Realty</span>
      </div>
      <p class="text-blue-200 text-sm leading-relaxed">{SITE.tagline}</p>
    </div>

    <div>
      <h3 class="font-semibold mb-3 text-amber-300">Navegación</h3>
      <ul class="space-y-2 text-sm text-blue-200">
        <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
        <li><a href="/propiedades" class="hover:text-white transition-colors">Propiedades</a></li>
        <li><a href="/servicios" class="hover:text-white transition-colors">Servicios</a></li>
        <li><a href="/sobre-nosotros" class="hover:text-white transition-colors">Sobre Nosotros</a></li>
        <li><a href="/contacto" class="hover:text-white transition-colors">Contacto</a></li>
      </ul>
    </div>

    <div>
      <h3 class="font-semibold mb-3 text-amber-300">Contacto</h3>
      <ul class="space-y-2 text-sm text-blue-200">
        <li>
          <a href={`tel:${SITE.phone}`} class="hover:text-white transition-colors flex items-center gap-2">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.57a1 1 0 01-.24 1.01l-2.21 2.21z"/></svg>
            {SITE.phone}
          </a>
        </li>
        <li>
          <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors flex items-center gap-2">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            {SITE.email}
          </a>
        </li>
        <li class="flex items-start gap-2">
          <svg class="h-4 w-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
          {SITE.address}
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-blue-800 text-center text-xs text-blue-300 py-4 px-4">
    <p>
      © {year} {SITE.name}. Todos los derechos reservados.
      <a href="/aviso-legal" class="hover:text-white ml-2">Aviso Legal</a> ·
      <a href="/politica-de-privacidad" class="hover:text-white ml-1">Privacidad</a> ·
      <a href="/politica-de-cookies" class="hover:text-white ml-1">Cookies</a>
    </p>
  </div>
</footer>
